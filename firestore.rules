rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: is the requester an admin?
    // GUARD with exists() — if config/admin_emails is missing or malformed,
    // get(...).data.emails throws, which makes EVERY rule that calls isAdmin()
    // (even via `|| isAdmin()` / `isAdmin() || …`) evaluate to an error → permission
    // denied. That bug blocked players from placing bets ("Missing or insufficient
    // permissions") because the balance-update rule evaluated isAdmin() first.
    function isAdmin() {
      return request.auth != null
             && exists(/databases/$(database)/documents/config/admin_emails)
             && request.auth.token.email in
                get(/databases/$(database)/documents/config/admin_emails).data.emails;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // ── config ────────────────────────────────────────────────
    // Everyone signed in can READ config (so the client can check
    // invite_only / admin_emails). Only admins can write.
    match /config/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ── users ─────────────────────────────────────────────────
    // Each user doc is keyed by uid.
    // - Read: any signed-in player (so leaderboard works).
    // - Create: the user themselves, on first sign-in, with starting
    //   balance only. They cannot set their own balance to a custom value.
    // - Update: only admins (to adjust balances) or the server-side
    //   settlement path. Players CANNOT edit their own balance directly.
    match /users/{uid} {
      // PUBLIC read: friends game with no sensitive data (just displayName +
      // balance). Lets the LillyRose dashboard server-side fetch the
      // leaderboard via Firestore REST without auth tokens.
      allow read: if true;
      // Self-create on first sign-in (starting balance only), OR admin seeding
      // a user doc (e.g. the LillyRose AI player, whose uid != admin's uid).
      allow create: if (isSelf(uid)
                        && request.resource.data.balance == 1000
                        && request.resource.data.email == request.auth.token.email)
                    || isAdmin();
      // Admins can adjust anything (balance corrections, settlement credits).
      // A player may update ONLY their own balance + openStake, and ONLY in a way
      // that PRESERVES their asset value (balance + openStake). Placing a bet moves
      // cash → openStake; cancelling/editing moves it back — the total never changes.
      // This is a stronger guard than the old ±10-200 bound: a player can shuffle
      // between cash and locked stake but can NEVER inflate their own total (winnings
      // are credited admin-side at settlement, which raises openStake-released balance).
      // Self path is checked FIRST so a normal bet never depends on isAdmin()
      // (which needs the config doc). isAdmin() is the fallback.
      // NOTE: rules can't see the matching bet write in the same transaction; the
      // asset-preservation invariant is the guard. Friends game, no real money.
      // Old docs may lack openStake → treat missing as 0 (backfilled 2026-06-13).
      allow update: if (isSelf(uid)
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['balance', 'openStake'])
                        && request.resource.data.balance is number
                        && request.resource.data.balance >= 0
                        && request.resource.data.openStake is number
                        && request.resource.data.openStake >= 0
                        && (request.resource.data.balance + request.resource.data.openStake)
                           == (resource.data.balance
                               + (('openStake' in resource.data) ? resource.data.openStake : 0)))
                    || isAdmin();
      allow delete: if isAdmin();
    }

    // ── matches ───────────────────────────────────────────────
    // Read: any signed-in player. Write: admins only.
    match /matches/{matchId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ── bets ──────────────────────────────────────────────────
    // Read own bets, plus admins can read all.
    // Create: signed-in user placing a bet on themselves, on a match
    // that hasn't kicked off, with valid stake.
    // Update / delete: admins only (e.g. settlement, void).
    match /bets/{betId} {
      // AI-LillyRose bets are visible to everyone (it's a public AI player).
      // `resource == null` MUST come first: the place-bet transaction does a
      // tx.get() on the deterministic bet id (uid__match__market) to block
      // duplicates. On a FIRST bet that doc doesn't exist yet — without this
      // guard the get() is denied ("Missing or insufficient permissions") and
      // EVERY first-time bet on a match/market fails. Reading a non-existent
      // doc leaks nothing.
      allow read: if isSignedIn() && (
                    resource == null
                    || resource.data.userId == request.auth.uid
                    || resource.data.userId == 'lillyrose-ai'
                    || isAdmin()
                  );
      // Players create bets only as themselves. Admin can create bets as any user
      // (used to seed LillyRose's AI picks from the admin panel).
      allow create: if isSignedIn()
                    && (request.resource.data.userId == request.auth.uid || isAdmin())
                    && request.resource.data.stake is number
                    && request.resource.data.stake >= 10
                    && request.resource.data.stake <= 200
                    && request.resource.data.status == 'open';
      // Owners can edit/delete their own bets while still open
      // (used by the My Bets ✏️/🗑️ buttons before kickoff).
      // We don't check match kickoff in rules — frontend enforces that
      // and a self-inflicted late delete only refunds the user.
      allow update, delete: if isAdmin()
                            || (request.auth.uid == resource.data.userId
                                && resource.data.status == 'open');
    }

    // ── results ───────────────────────────────────────────────
    // Per-match prediction summary written by the admin at settlement so EVERY
    // player can see who predicted what once a match is over (bets themselves
    // stay private before kickoff; this only reveals them post-settlement).
    match /results/{matchId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ── champions ─────────────────────────────────────────────
    // "Predict the champion" — one doc per user, keyed by uid. No stake; a
    // correct pick is paid (100 x locked outright odds) by the admin settlement.
    // A user may write ONLY their own pick doc; admins can write any (to mark
    // awarded/won on settlement). Frontend enforces the pre-tournament cutoff,
    // consistent with how bets enforce kickoff client-side.
    match /champions/{uid} {
      allow read: if isSignedIn();
      allow create, update: if (isSelf(uid)
                                && request.resource.data.userId == request.auth.uid
                                && request.resource.data.pick is string)
                            || isAdmin();
      allow delete: if isAdmin();
    }

    // ── teach_bookings ────────────────────────────────────────
    // PUBLIC lesson-booking inbox for the AI Teaching booking page
    // (teaching-booking GitHub Pages). The page is UNAUTHENTICATED, so create
    // must be allowed with auth==null — but every booking carries a student's
    // name + email, so client READ is FORBIDDEN (no leaderboard, no listing).
    // LillyRose drains this collection server-side via the Firebase Admin SDK
    // (service account) which BYPASSES these rules; the public can only drop a
    // booking in, never read what's there. Validated + size-capped to limit abuse.
    match /teach_bookings/{id} {
      allow read, update, delete: if false;          // never readable client-side
      allow create: if request.resource.data.email is string
                    && request.resource.data.email.size() <= 120
                    && request.resource.data.email.matches('^[^@\\s]+@[^@\\s]+\\.[^@\\s]+$')
                    && request.resource.data.slot_date is string
                    && request.resource.data.slot_uk is string
                    && request.resource.data.status == 'pending'
                    && request.resource.data.kind in ['new', 'existing']
                    && (!('note' in request.resource.data)
                        || request.resource.data.note.size() <= 500)
                    // new students must give a name; existing are resolved by email
                    && (request.resource.data.kind == 'existing'
                        || (request.resource.data.name is string
                            && request.resource.data.name.size() > 0
                            && request.resource.data.name.size() <= 80));
    }

    // ── arcade_scores ─────────────────────────────────────────
    // PUBLIC leaderboard for the game-arcade (kids' HTML5 games, GitHub Pages).
    // Unauthenticated: anyone can READ the top scores, and anyone can CREATE a
    // score entry (name + score), validated + size-capped. Entries are immutable
    // (no update/delete) so the board can't be tampered with. Migrated off the
    // old Google Apps Script + Sheet backend 2026-07-05.
    match /arcade_scores/{id} {
      allow read: if true;
      allow create: if request.resource.data.name is string
                    && request.resource.data.name.size() > 0
                    && request.resource.data.name.size() <= 12
                    && request.resource.data.score is int
                    && request.resource.data.score >= 0
                    && request.resource.data.score < 100000000
                    && request.resource.data.game is string
                    && request.resource.data.game.size() <= 40;
      allow update, delete: if false;
    }
  }
}
