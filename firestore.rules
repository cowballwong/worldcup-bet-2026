rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: is the requester an admin?
    // GUARD with exists() — if config/admin_emails is missing or malformed,
    // get(...).data.emails throws, which makes EVERY rule that calls isAdmin()
    // (even via `|| isAdmin()` / `isAdmin() || …`) evaluate to an error → permission
    // denied. That bug blocked players from placing bets ("Missing or insufficient
    // permissions") because the balance-update rule evaluated isAdmin() first.
    function isAdmin() {
      return request.auth != null
             && exists(/databases/$(database)/documents/config/admin_emails)
             && request.auth.token.email in
                get(/databases/$(database)/documents/config/admin_emails).data.emails;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // ── config ────────────────────────────────────────────────
    // Everyone signed in can READ config (so the client can check
    // invite_only / admin_emails). Only admins can write.
    match /config/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ── users ─────────────────────────────────────────────────
    // Each user doc is keyed by uid.
    // - Read: any signed-in player (so leaderboard works).
    // - Create: the user themselves, on first sign-in, with starting
    //   balance only. They cannot set their own balance to a custom value.
    // - Update: only admins (to adjust balances) or the server-side
    //   settlement path. Players CANNOT edit their own balance directly.
    match /users/{uid} {
      // PUBLIC read: friends game with no sensitive data (just displayName +
      // balance). Lets the LillyRose dashboard server-side fetch the
      // leaderboard via Firestore REST without auth tokens.
      allow read: if true;
      // Self-create on first sign-in (starting balance only), OR admin seeding
      // a user doc (e.g. the LillyRose AI player, whose uid != admin's uid).
      allow create: if (isSelf(uid)
                        && request.resource.data.balance == 1000
                        && request.resource.data.email == request.auth.token.email)
                    || isAdmin();
      // Admins can adjust anything (balance corrections, settlement credits).
      // A player may update ONLY their own balance, and ONLY by a valid stake-sized
      // amount (10-200) — DOWN to pay for a bet, or UP to refund one they delete /
      // edit before kickoff (the My Bets ✏️/🗑️ buttons). They still cannot credit
      // themselves winnings (settlement is admin-side) or change other fields.
      // Self path is checked FIRST so a normal bet never depends on isAdmin()
      // (which needs the config doc). isAdmin() is the fallback.
      // NOTE: rules can't see the matching bet write in the same transaction, so the
      // ±10-200 bound is the guard. Friends game, no real money — acceptable, and
      // symmetric to the existing stake-decrease allowance.
      allow update: if (isSelf(uid)
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['balance'])
                        && request.resource.data.balance is number
                        && request.resource.data.balance >= 0
                        && (
                             ( (resource.data.balance - request.resource.data.balance) >= 10
                               && (resource.data.balance - request.resource.data.balance) <= 200 )   // pay stake (down)
                          || ( (request.resource.data.balance - resource.data.balance) >= 10
                               && (request.resource.data.balance - resource.data.balance) <= 200 )   // refund bet (up)
                        ))
                    || isAdmin();
      allow delete: if isAdmin();
    }

    // ── matches ───────────────────────────────────────────────
    // Read: any signed-in player. Write: admins only.
    match /matches/{matchId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ── bets ──────────────────────────────────────────────────
    // Read own bets, plus admins can read all.
    // Create: signed-in user placing a bet on themselves, on a match
    // that hasn't kicked off, with valid stake.
    // Update / delete: admins only (e.g. settlement, void).
    match /bets/{betId} {
      // AI-LillyRose bets are visible to everyone (it's a public AI player).
      allow read: if isSignedIn() && (
                    resource.data.userId == request.auth.uid
                    || resource.data.userId == 'lillyrose-ai'
                    || isAdmin()
                  );
      // Players create bets only as themselves. Admin can create bets as any user
      // (used to seed LillyRose's AI picks from the admin panel).
      allow create: if isSignedIn()
                    && (request.resource.data.userId == request.auth.uid || isAdmin())
                    && request.resource.data.stake is number
                    && request.resource.data.stake >= 10
                    && request.resource.data.stake <= 200
                    && request.resource.data.status == 'open';
      // Owners can edit/delete their own bets while still open
      // (used by the My Bets ✏️/🗑️ buttons before kickoff).
      // We don't check match kickoff in rules — frontend enforces that
      // and a self-inflicted late delete only refunds the user.
      allow update, delete: if isAdmin()
                            || (request.auth.uid == resource.data.userId
                                && resource.data.status == 'open');
    }

    // ── results ───────────────────────────────────────────────
    // Per-match prediction summary written by the admin at settlement so EVERY
    // player can see who predicted what once a match is over (bets themselves
    // stay private before kickoff; this only reveals them post-settlement).
    match /results/{matchId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ── champions ─────────────────────────────────────────────
    // "Predict the champion" — one doc per user, keyed by uid. No stake; a
    // correct pick is paid (100 x locked outright odds) by the admin settlement.
    // A user may write ONLY their own pick doc; admins can write any (to mark
    // awarded/won on settlement). Frontend enforces the pre-tournament cutoff,
    // consistent with how bets enforce kickoff client-side.
    match /champions/{uid} {
      allow read: if isSignedIn();
      allow create, update: if (isSelf(uid)
                                && request.resource.data.userId == request.auth.uid
                                && request.resource.data.pick is string)
                            || isAdmin();
      allow delete: if isAdmin();
    }
  }
}
